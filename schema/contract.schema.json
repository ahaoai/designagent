{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DesignAgent Skill Contract Schema",
  "type": "object",
  "required": ["name", "version", "entry", "io", "runtime", "constraints"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "entry": {
      "type": "object",
      "required": ["type", "steps"],
      "properties": {
        "type": { "type": "string", "enum": ["sequential", "parallel", "conditional"] },
        "steps": { "type": "array", "items": { "type": "string" } }
      }
    },
    "io": {
      "type": "object",
      "required": ["input", "output"],
      "properties": {
        "input": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["unstructured", "structured", "mixed"] },
            "required": { "type": "array", "items": { "type": "string" } },
            "optional": { "type": "array", "items": { "type": "string" } }
          }
        },
        "output": {
          "type": "object",
          "required": ["formats"],
          "properties": {
            "formats": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["mode", "execution"],
      "properties": {
        "mode": { "type": "string", "enum": ["stateless", "session"] },
        "execution": { "type": "string", "enum": ["prompt-driven"] }
      }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
